<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wina.agency.contractMgmt.repository.ContractMgmtRepository">
  <select id="retrieveContractList" resultType="map">
    SELECT * FROM TWA_CONTRACT_MST WHERE STATUS = 'A'
  </select>
  <select id="retrieveContractDetail" resultType="map">
    SELECT * FROM TWA_CONTRACT_MST WHERE CONTRACT_NO = #{contractNo}
  </select>
  <insert id="saveContract">
    INSERT INTO TWA_CONTRACT_MST (CONTRACT_NO, PARTNER_CD) VALUES (#{contractNo}, #{partnerCd})
  </insert>
</mapper>

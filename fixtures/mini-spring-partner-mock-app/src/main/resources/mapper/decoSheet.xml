<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wina.partner.matMgmt.decoSheet.repository.DecoSheetRepository">
  <select id="retrieveDecoShetAbcsRqusList" resultType="map">
    SELECT * FROM TB_HODS401 WHERE STATUS = 'A'
  </select>
  <insert id="insertTbHods401">
    INSERT INTO TB_HODS401 (REQ_NO, MTRL_CD) VALUES (#{reqNo}, #{mtrlCd})
  </insert>
  <insert id="insertTbHods401B">
    INSERT INTO TB_HODS408 (REQ_NO, MTRL_CD) VALUES (#{reqNo}, #{mtrlCd})
  </insert>
</mapper>

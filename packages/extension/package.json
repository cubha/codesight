{
  "name": "codebase-arch-viz",
  "displayName": "Codebase Architecture Visualizer",
  "description": "Architecture diagrams for 13 frameworks — route hierarchy, component trees, DB schema, and FE↔BE cross-project analysis. Static analysis, no API key needed.",
  "version": "1.2.50",
  "publisher": "cubha",
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#060810",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cubha/codesight"
  },
  "bugs": {
    "url": "https://github.com/cubha/codesight/issues"
  },
  "homepage": "https://github.com/cubha/codesight#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "architecture",
    "visualization",
    "diagram",
    "mermaid",
    "nextjs",
    "nuxt",
    "sveltekit",
    "nestjs",
    "django",
    "fastapi",
    "flask",
    "spring",
    "vue",
    "angular",
    "remix",
    "prisma",
    "drizzle",
    "typeorm"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:codesight.analyze",
    "onView:codesight.sidebar",
    "onView:codesight.panelView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codesight-sidebar",
          "title": "Codebase Visualizer",
          "icon": "media/icon-activity.svg"
        }
      ],
      "panel": [
        {
          "id": "codesight-panel",
          "title": "Codebase Visualizer",
          "icon": "media/icon-activity.svg"
        }
      ]
    },
    "views": {
      "codesight-sidebar": [
        {
          "type": "webview",
          "id": "codesight.sidebar",
          "name": "Codebase Visualizer"
        }
      ],
      "codesight-panel": [
        {
          "type": "webview",
          "id": "codesight.panelView",
          "name": "Analysis"
        }
      ]
    },
    "commands": [
      {
        "command": "codesight.analyze",
        "title": "Codebase Viz: Analyze Project"
      },
      {
        "command": "codesight.selectFolder",
        "title": "Codebase Viz: Select Workspace Folder"
      },
      {
        "command": "codesight.setApiKey",
        "title": "Codebase Viz: Set API Key"
      },
      {
        "command": "codesight.clearApiKey",
        "title": "Codebase Viz: Clear API Key"
      }
    ],
    "configuration": {
      "title": "Codebase Visualizer",
      "properties": {
        "codesight.language": {
          "type": "string",
          "enum": [
            "auto",
            "ko",
            "en",
            "ja",
            "zh-cn"
          ],
          "enumDescriptions": [
            "Follow VS Code display language",
            "한국어",
            "English",
            "日本語",
            "中文 (简体)"
          ],
          "default": "auto",
          "description": "Display language for Codebase Viz UI (sidebar, viewer, messages). 'auto' follows VS Code display language."
        },
        "codesight.llm.provider": {
          "type": "string",
          "enum": ["anthropic", "google", "openai"],
          "enumDescriptions": [
            "Anthropic Claude (claude-sonnet-4-6)",
            "Google Gemini (gemini-2.5-flash) — free tier available",
            "OpenAI (gpt-4o)"
          ],
          "default": "anthropic",
          "description": "LLM provider to use for AI-powered analysis. Each provider requires its own API key."
        },
        "codesight.model": {
          "type": "string",
          "default": "",
          "description": "Override the default model for the selected provider. Leave empty to use the provider default."
        },
        "codesight.enableLLM": {
          "type": "boolean",
          "default": false,
          "description": "Enable AI-powered analysis (requires an API key for the selected provider)"
        },
        "codesight.grouping.maxNodesPerGroup": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "maximum": 200,
          "description": "Hierarchical grouping: max nodes per subgraph before chunking (Tab1/Tab2)"
        },
        "codesight.grouping.maxDepth": {
          "type": "number",
          "default": 8,
          "minimum": 1,
          "maximum": 20,
          "description": "Hierarchical grouping: max URL segment depth for nesting (Tab1/Tab2)"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "package": "vsce package --no-dependencies",
    "publish:vscode": "vsce publish --no-dependencies --pat $AZURE_DEVOPS_PAT",
    "publish:ovsx": "ovsx publish --pat $OPEN_VSX_TOKEN",
    "publish:all": "pnpm publish:vscode && pnpm publish:ovsx"
  },
  "dependencies": {
    "@codebase-viz/core": "workspace:*",
    "@codebase-viz/llm": "workspace:*",
    "@codebase-viz/renderer": "workspace:*",
    "@codebase-viz/types": "workspace:*"
  },
  "devDependencies": {
    "@mermaid-js/layout-elk": "^0.2.1",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "ffmpeg-static": "^5.3.0",
    "ovsx": "^0.9.0",
    "playwright": "^1.59.1",
    "typescript": "*"
  }
}

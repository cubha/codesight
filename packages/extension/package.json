{
  "name": "codebase-arch-viz",
  "displayName": "Codebase Architecture Visualizer",
  "description": "Routes for 7 frameworks out of the box. Full diagrams for Next.js + Supabase; add Claude API key to fill components & DB on other stacks.",
  "version": "0.4.3",
  "publisher": "cubha",
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#060810",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cubha/codesight"
  },
  "bugs": {
    "url": "https://github.com/cubha/codesight/issues"
  },
  "homepage": "https://github.com/cubha/codesight#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "architecture",
    "visualization",
    "diagram",
    "mermaid",
    "nextjs",
    "nuxt",
    "sveltekit",
    "nestjs",
    "django",
    "fastapi",
    "spring"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:codesight.analyze",
    "onView:codesight.sidebar",
    "onView:codesight.panelView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codesight-sidebar",
          "title": "CodeSight",
          "icon": "media/icon-activity.svg"
        }
      ],
      "panel": [
        {
          "id": "codesight-panel",
          "title": "CodeSight",
          "icon": "media/icon-activity.svg"
        }
      ]
    },
    "views": {
      "codesight-sidebar": [
        {
          "type": "webview",
          "id": "codesight.sidebar",
          "name": "CodeSight"
        }
      ],
      "codesight-panel": [
        {
          "type": "webview",
          "id": "codesight.panelView",
          "name": "Analysis"
        }
      ]
    },
    "commands": [
      {
        "command": "codesight.analyze",
        "title": "CodeSight: Analyze Project"
      },
      {
        "command": "codesight.setApiKey",
        "title": "CodeSight: Set Anthropic API Key"
      },
      {
        "command": "codesight.clearApiKey",
        "title": "CodeSight: Clear Anthropic API Key"
      }
    ],
    "configuration": {
      "title": "CodeSight",
      "properties": {
        "codesight.model": {
          "type": "string",
          "default": "claude-sonnet-4-6",
          "description": "Claude model to use for LLM analysis (requires API key)"
        },
        "codesight.enableLLM": {
          "type": "boolean",
          "default": false,
          "description": "Enable LLM-based analysis (requires Anthropic API key)"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@codebase-viz/core": "workspace:*",
    "@codebase-viz/llm": "workspace:*",
    "@codebase-viz/renderer": "workspace:*",
    "@codebase-viz/types": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "typescript": "*"
  }
}
